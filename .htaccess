Options -Indexes

# URL Rewriting
RewriteEngine On
RewriteBase /wealthdash/

# Redirect to HTTPS (production only - comment out on XAMPP)
# RewriteCond %{HTTPS} off
# RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Front controller - send all non-file/dir requests to index.php
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php?url=$1 [QSA,L]

# Block sensitive files (BUG-04 fix)
<Files ".env">
    Order allow,deny
    Deny from all
</Files>

<Files "composer.json">
    Order allow,deny
    Deny from all
</Files>

# Block sensitive file types (BUG-04 fix - added .bak .tmp .orig)
<FilesMatch "\.(sql|log|sh|bat|bak|tmp|orig|swp|old)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Security headers (only if mod_headers available)
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
</IfModule>
